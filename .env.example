# Supabase (PostgreSQL) — used by Next.js API and Prisma (web only)
# Copy to .env and set your values. Password in URL: use %40 for @

DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Optional: JWT secret for auth tokens (default used if not set)
JWT_SECRET=your-secret

# Optional: for React Native / external clients
NEXT_PUBLIC_API_URL=http://localhost:3000

# Super Admin payment details (shown to ISP admins for manual subscription payment)
PLATFORM_JAZZCASH_NUMBER=03001234567
PLATFORM_EAZYPAISA_NUMBER=03001234567
PLATFORM_BANK_DETAILS=Bank Name, IBAN, Account Title

# AI: Google Gemini (used for any AI features; no OpenAI)
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
